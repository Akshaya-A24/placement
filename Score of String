import java.util.Scanner;

public class Solution {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        String s = sc.next();
        
        int score = 0;
        
        // Loop stops 1 character early so i + 1 doesn't crash
        for (int i = 0; i < s.length() - 1; i++) {
            int char1 = s.charAt(i);     // Gets ASCII number of current letter
            int char2 = s.charAt(i + 1); // Gets ASCII number of next letter
            
            int diff = char1 - char2;
            
            // If the subtraction is negative, flip it to positive manually
            if (diff < 0) {
                diff = -diff;
            }
            
            score = score + diff;
        }
        
        System.out.println(score);
    }
}
